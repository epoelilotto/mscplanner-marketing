---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";

const PLANNER_URL = "https://ae-planner-proxy.vercel.app";
const DEMO_LINK = "https://cal.com/elisamscplanner/20min";

// Lead form submission endpoint.
// Set this to your Formspree form URL (e.g. "https://formspree.io/f/XXXXXXX")
// once the account is created. While empty, the form falls back to a mailto:
// action so it still works with zero setup.
const FORMSPREE_ENDPOINT = "https://formspree.io/f/meewpdjv";
const FALLBACK_EMAIL = "elisa@mscplanner.com";
const formAction = FORMSPREE_ENDPOINT || `mailto:${FALLBACK_EMAIL}`;
const formMethod = FORMSPREE_ENDPOINT ? "POST" : "post";
const formEnctype = FORMSPREE_ENDPOINT ? undefined : "text/plain";

const blocks = [
  {
    title: "What we cover",
    items: ["Live demo walkthrough", "How we encode your programme rules", "Branding and subdomain setup", "Timeline and effort estimate"],
  },
  {
    title: "What you need",
    items: ["Your MSc programme guide (PDF)", "30 minutes of your time", "No IT department involvement", "No budget commitment upfront"],
  },
];

const fieldClass = "mt-1.5 w-full rounded-md border border-slate-700 bg-slate-900 px-3.5 py-2.5 text-sm text-white placeholder:text-slate-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500";
const labelClass = "block text-sm font-medium text-slate-200";
---

<Base title="Contact — MSc Study Planner" description="Get in touch to bring MSc Study Planner to your university. Twenty-minute call, no commitment.">
  <Navbar />
  <main class="flex-1">
    <div class="min-h-screen bg-slate-950">
      <div class="mx-auto max-w-3xl px-6 py-24 sm:py-32">
        <div class="mb-8 h-1 w-16 rounded-full bg-blue-600"></div>
        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          Bring MSc Study Planner to your university.
        </h1>
        <p class="mt-6 text-lg text-slate-200">
          Twenty-minute call. We'll walk through the live demo, show how the multi-tenant setup works, and scope what it would take for your programme.
        </p>
        <p class="mt-4 text-sm font-medium text-blue-400">
          Currently live with MSc Aerospace Engineering students at TU Delft.
        </p>

        <div class="mt-12 grid gap-6 sm:grid-cols-2">
          {blocks.map((block) => (
            <div class="rounded-xl border border-slate-800 bg-slate-900/60 p-6">
              <h2 class="font-semibold text-white mb-4">{block.title}</h2>
              <ul class="space-y-2">
                {block.items.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-slate-300">
                    <span class="mt-0.5 h-4 w-4 shrink-0 rounded-full bg-blue-600/30 flex items-center justify-center">
                      <span class="h-1.5 w-1.5 rounded-full bg-blue-400"></span>
                    </span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <div class="mt-12 flex flex-wrap gap-4">
          <a
            href={DEMO_LINK}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center rounded-md bg-blue-600 px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-950 transition hover:bg-blue-500"
          >
            Book a 20-min demo
          </a>
          <a
            href={PLANNER_URL}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center rounded-md border border-slate-700 px-8 py-3 text-sm font-semibold text-white transition hover:border-blue-500 hover:text-blue-400"
          >
            See a live student demo →
          </a>
        </div>

        <!-- Low-commitment lead form -->
        <div class="mt-16 rounded-2xl border border-slate-800 bg-slate-900/60 p-6 sm:p-8">
          <h2 class="text-xl font-semibold text-white">
            Not ready for a call?
          </h2>
          <p class="mt-2 text-sm text-slate-300">
            Send us a note about your programme and we'll reply by email.
          </p>

          <form
            action={formAction}
            method={formMethod}
            enctype={formEnctype}
            class="mt-6 grid gap-5 sm:grid-cols-2"
          >
            <!-- Email subject label for the inbox -->
            <input type="hidden" name="_subject" value="MSc Study Planner — new enquiry" />
            <!-- Honeypot: hidden from humans, catches bots -->
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

            <div>
              <label for="name" class={labelClass}>Name</label>
              <input id="name" name="name" type="text" required autocomplete="name" class={fieldClass} placeholder="Your name" />
            </div>
            <div>
              <label for="university" class={labelClass}>University</label>
              <input id="university" name="university" type="text" required class={fieldClass} placeholder="e.g. TU Delft" />
            </div>
            <div>
              <label for="role" class={labelClass}>Your role</label>
              <input id="role" name="role" type="text" class={fieldClass} placeholder="e.g. Programme coordinator" />
            </div>
            <div>
              <label for="programme" class={labelClass}>MSc programme</label>
              <input id="programme" name="programme" type="text" class={fieldClass} placeholder="e.g. MSc Computer Science" />
            </div>
            <div class="sm:col-span-2">
              <label for="email" class={labelClass}>Email</label>
              <input id="email" name="email" type="email" required autocomplete="email" class={fieldClass} placeholder="you@university.edu" />
            </div>
            <div class="sm:col-span-2">
              <label for="message" class={labelClass}>Message</label>
              <textarea id="message" name="message" rows="4" class={fieldClass} placeholder="Tell us a bit about your programme and what you're looking for."></textarea>
            </div>
            <div class="sm:col-span-2">
              <button
                type="submit"
                class="inline-flex items-center justify-center rounded-md bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-950 transition hover:bg-blue-500"
              >
                Send message
              </button>
            </div>
          </form>
        </div>

        <p class="mt-8 text-sm text-slate-400">
          Or email directly:{" "}
          <a href="mailto:alessandro@mscplanner.com" class="underline underline-offset-2 hover:text-slate-200">
            alessandro@mscplanner.com
          </a>{" "}
          or{" "}
          <a href="mailto:elisa@mscplanner.com" class="underline underline-offset-2 hover:text-slate-200">
            elisa@mscplanner.com
          </a>
        </p>
      </div>
    </div>
  </main>
</Base>
