---
const steps = [
  {
    title: "Pick your programme & track",
    body: "The student selects their MSc programme and specialisation. Mandatory courses pre-load instantly from your validated catalogue.",
  },
  {
    title: "AI suggests electives",
    body: "An AI model analyses the student profile against the full course catalogue and surfaces electives that fit their track, interests, and remaining ECTS budget.",
    badge: "AI-powered",
  },
  {
    title: "Real-time AI validation",
    body: "Every change is validated live — ECTS totals, prerequisite chains, skills & elective requirements, and scheduling conflicts flagged before they become a problem.",
  },
  {
    title: "Share with your advisor",
    body: "One link generates a shareable read-only plan. No login, no PDF export, no back-and-forth email.",
  },
];
---

<section class="border-b border-slate-200 bg-white">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <p class="text-xs font-semibold uppercase tracking-widest text-blue-600">How it works</p>
    <h2 class="mt-3 max-w-2xl text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
      From blank page to validated plan — in under 10 minutes.
    </h2>
    <p class="mt-4 max-w-2xl text-slate-600">
      What your students experience. Setting it up for your programme takes us about two weeks — see <a href="/#universities" class="font-medium text-blue-600 underline underline-offset-2 hover:text-blue-500">bringing it to your campus</a>.
    </p>

    <div class="mt-14 grid gap-6 lg:grid-cols-4">
      {steps.map((s, i) => (
        <div class="relative">
          <div class="group relative flex h-full flex-col overflow-hidden rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-blue-300 hover:shadow-md">
            <span
              class="pointer-events-none absolute -right-3 -top-5 text-7xl font-extrabold text-slate-100 select-none"
              aria-hidden="true"
            >
              {String(i + 1).padStart(2, "0")}
            </span>

            <div class="relative">
              <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-blue-600 text-white">
                {i === 0 && (
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
                  </svg>
                )}
                {i === 1 && (
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" />
                  </svg>
                )}
                {i === 2 && (
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                  </svg>
                )}
                {i === 3 && (
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.933 2.185 2.25 2.25 0 00-3.933-2.185zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z" />
                  </svg>
                )}
              </div>

              {s.badge && (
                <span class="mb-2 inline-block rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-semibold text-indigo-600">
                  {s.badge}
                </span>
              )}

              <h3 class="font-semibold text-slate-900">{s.title}</h3>
              <p class="mt-2 text-sm text-slate-500">{s.body}</p>
            </div>
          </div>

          {i < steps.length - 1 && (
            <div class="absolute top-1/2 -right-3 z-10 hidden -translate-y-1/2 lg:flex" aria-hidden="true">
              <svg class="h-5 w-5 text-slate-300" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M12.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L15.586 11H4a1 1 0 110-2h11.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
