---
const steps = [
  {
    number: "1",
    title: "Pick your programme & track",
    body: "The student selects their MSc programme and specialisation. Mandatory courses pre-load instantly from your validated catalogue.",
  },
  {
    number: "2",
    title: "AI suggests electives",
    body: "An AI model analyses the student profile against the full course catalogue and surfaces electives that fit their track, interests, and remaining EC budget.",
  },
  {
    number: "3",
    title: "Real-time validation",
    body: "Every change is validated live — EC totals, prerequisite chains, PPD requirements, and scheduling conflicts flagged before they become a problem.",
  },
  {
    number: "4",
    title: "Share with your advisor",
    body: "One link generates a shareable read-only plan. No login, no PDF export, no back-and-forth email.",
  },
];
---

<section class="border-b border-slate-200">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <h2 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">How it works</h2>
    <p class="mt-4 max-w-xl text-slate-600">From blank page to validated plan in under ten minutes.</p>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((s) => (
        <div class="group relative rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-blue-300 hover:ring-2 hover:ring-blue-100">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">
            {s.number}
          </div>
          <h3 class="font-semibold text-slate-900">{s.title}</h3>
          <p class="mt-2 text-sm text-slate-500">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
