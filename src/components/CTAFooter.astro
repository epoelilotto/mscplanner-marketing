---
const PLANNER_URL = "https://ae-planner-proxy.vercel.app";
const DEMO_MAILTO = "mailto:alessandromiccolo2003@gmail.com?subject=MSC%20Study%20Planner%20Demo%20Request&body=University%20name%3A%0AProgramme%3A%0AYour%20role%3A";
---

<section class="bg-slate-950">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24 text-center">
    <div class="mx-auto mb-6 h-1 w-16 rounded-full bg-blue-600"></div>
    <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
      Bring MSC Study Planner to your university.
    </h2>
    <p class="mt-4 text-lg text-slate-300 max-w-xl mx-auto">
      Twenty-minute call. We'll walk through the demo, show how the setup works, and scope what it would take for your programme.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href={DEMO_MAILTO}
        class="inline-flex items-center justify-center rounded-md bg-blue-600 px-8 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-950 transition hover:bg-blue-500"
      >
        Book a 20-min demo
      </a>
      <a
        href={PLANNER_URL}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center rounded-md border border-slate-700 px-8 py-3 text-sm font-semibold text-white transition hover:border-blue-500 hover:text-blue-400"
      >
        Try the planner first →
      </a>
    </div>
  </div>
</section>
