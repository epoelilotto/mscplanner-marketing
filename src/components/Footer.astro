---
const PLANNER_URL = "https://ae-planner-proxy.vercel.app";

const nav = [
  { href: "/#how-it-works", label: "How it works" },
  { href: "/#faq-section", label: "FAQ" },
  { href: "/contact", label: "Contact" },
  { href: PLANNER_URL, label: "See it live", external: true },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-6xl px-6 py-14">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 text-white font-semibold text-base tracking-tight">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="28" height="28" rx="7" fill="#2563EB"/>
            <path d="M8 14.5l4 4 8-9" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          MSc Study Planner
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-slate-400">
          Real-time study plan validation for MSc programmes — so coordinators stop fixing invalid plans over email.
        </p>
        <p class="mt-4 max-w-sm text-xs leading-relaxed text-slate-500">
          Plans stored locally by default · EU infrastructure · GDPR-compliant by design.
        </p>
      </div>

      <!-- Nav -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500">Explore</p>
        <ul class="mt-4 space-y-2.5">
          {nav.map((l) => (
            <li>
              <a
                href={l.href}
                target={l.external ? "_blank" : undefined}
                rel={l.external ? "noreferrer" : undefined}
                class="text-sm text-slate-400 transition hover:text-white"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-500">Get in touch</p>
        <ul class="mt-4 space-y-2.5">
          <li>
            <a href="mailto:elisa@mscplanner.com" class="text-sm text-slate-400 transition hover:text-white">
              elisa@mscplanner.com
            </a>
          </li>
          <li>
            <a href="mailto:alessandro@mscplanner.com" class="text-sm text-slate-400 transition hover:text-white">
              alessandro@mscplanner.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col gap-2 border-t border-slate-800 pt-6 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between">
      <p>Built by Alessandro Miccolo &amp; Elisa Lotto</p>
      <p>&copy; {year} MSc Study Planner</p>
    </div>
  </div>
</footer>
