---
const PLANNER_URL = "https://ae-planner-proxy.vercel.app";
const DEMO_LINK = "https://cal.com/elisamscplanner/20min";
const metrics = [
  { metric: "180+", label: "courses encoded" },
  { metric: "5", label: "specialisation tracks" },
  { metric: "< 2 wks", label: "setup to live" },
];
const screens = [
  {
    src: "/screenshots/screenshot-1.png",
    alt: "MSc Study Planner — branded landing page for TU Delft Aerospace Engineering",
    number: "01",
    title: "Branded per institution",
  },
  {
    src: "/screenshots/screenshot-2.png",
    alt: "Track selection — choose your specialisation",
    number: "02",
    title: "Pick track and profile",
  },
  {
    src: "/screenshots/screenshot-3.png",
    alt: "Full study plan grid with live validation and AI recommendations",
    number: "03",
    title: "Live validation + AI",
  },
];
---

<section class="border-b border-slate-200 bg-white">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-8 py-10 sm:px-12 sm:py-14">
      <p class="text-xs font-semibold uppercase tracking-widest text-blue-600">
        Case study · TU Delft
      </p>
      <h2 class="mt-3 max-w-2xl text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
        From email chaos to self-service validation
      </h2>
      <p class="mt-5 max-w-2xl text-slate-600">
        MSc Aerospace Engineering students at TU Delft now validate their own study plans before advising
        appointments. MSc Study Planner encoded 180+ courses across 5 specialisation tracks — including
        prerequisite chains, EC requirements, and PPD credits — in under two weeks.
      </p>

      <div class="mt-8 grid gap-6 sm:grid-cols-3">
        {metrics.map((item) => (
          <div class="rounded-lg border border-slate-200 bg-white px-6 py-5 text-center shadow-sm">
            <p class="text-3xl font-bold text-blue-600">{item.metric}</p>
            <p class="mt-1 text-sm font-medium text-slate-700">{item.label}</p>
          </div>
        ))}
      </div>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={PLANNER_URL}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center rounded-md bg-blue-600 px-7 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-blue-500"
        >
          See the live planner →
        </a>
        <a
          href={DEMO_LINK}
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-blue-400 hover:text-blue-600"
        >
          Book a demo for your programme
        </a>
      </div>

      <!-- Screenshots: 01/02 side by side, 03 (live validation + AI) full width and larger -->
      <div class="mt-10 border-t border-slate-200 pt-8 grid grid-cols-1 gap-5 sm:grid-cols-2">
        {screens.map((s, i) => (
          <div class={i === 2 ? "sm:col-span-2" : ""}>
            <p class="mb-2 text-xs font-bold uppercase tracking-widest text-blue-600">{s.number} — {s.title}</p>
            <div class="overflow-hidden rounded-lg border border-slate-200 shadow-sm">
              <img
                src={s.src}
                alt={s.alt}
                class="w-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
