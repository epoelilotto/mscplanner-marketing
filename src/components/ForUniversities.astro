---
const DEMO_MAILTO = "mailto:alessandromiccolo2003@gmail.com?subject=MSC%20Study%20Planner%20Demo%20Request&body=University%20name%3A%0AProgramme%3A%0AYour%20role%3A";

const points = [
  { title: "Branded for your institution", body: "Your own catalogue, rules, branding, and subdomain." },
  { title: "Zero onboarding cost for students", body: "No account required. Students land, build, validate, share." },
  { title: "Programme analytics", body: "Aggregate elective demand and invalid configurations — anonymised." },
  { title: "We handle the rules", body: "Send us your programme guide. We encode and maintain the logic." },
];

const demoSteps = [
  "We walk through the live planner and show real validation in action.",
  "You describe your programme structure and rules.",
  "We give you a setup estimate and a price on the spot — no strings.",
];
---

<section id="universities" class="border-b border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-4xl px-6 py-20 sm:py-28 text-center">

    <!-- Pain statement — big and centered -->
    <p class="text-base font-semibold uppercase tracking-widest text-blue-500 mb-6">Bring it to your campus</p>
    <h2 class="text-4xl font-bold tracking-tight text-white sm:text-5xl max-w-3xl mx-auto leading-tight">
      Hundreds of plan validation emails pile up in your inbox every term.
    </h2>
    <p class="mt-4 text-lg font-medium text-blue-400">
      They should not be part of your job description.
    </p>

    <!-- Reply / solution -->
    <p class="mt-8 text-lg text-slate-300 max-w-2xl mx-auto">
      MSc Study Planner validates every student plan automatically — before the first email is ever written. If you coordinate an MSc, the 20-minute call below is all it takes to find out if it fits.
    </p>

    <!-- CTA -->
    <a
      href={DEMO_MAILTO}
      class="mt-10 inline-flex items-center justify-center rounded-md bg-blue-600 px-8 py-3.5 text-sm font-semibold text-white shadow-lg shadow-blue-900/50 transition hover:bg-blue-500"
    >
      Book a 20-min demo
    </a>

    <!-- What happens in the call -->
    <div class="mt-10 mx-auto max-w-sm text-left rounded-lg border border-slate-700 bg-slate-800/40 px-5 py-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">What happens in the 20 minutes</p>
      <ul class="mt-3 space-y-2">
        {demoSteps.map((step) => (
          <li class="flex items-start gap-2 text-sm text-slate-300">
            <span class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white">✓</span>
            {step}
          </li>
        ))}
      </ul>
    </div>

    <!-- GDPR -->
    <div class="mt-4 mx-auto max-w-sm text-left rounded-lg border border-slate-700 bg-slate-800/40 px-5 py-4">
      <p class="text-xs font-semibold uppercase tracking-wide text-blue-400">Data &amp; Privacy</p>
      <p class="mt-1 text-sm text-slate-300">
        Plans stored locally by default. All shared data on EU infrastructure. Never used for training.
        <span class="font-medium text-white">GDPR-compliant by design.</span>
      </p>
    </div>

    <!-- Testimonial placeholder — uncomment and fill in when first coordinator quote is received
    <figure class="mt-8 mx-auto max-w-lg rounded-lg border border-slate-700 bg-slate-800/40 px-5 py-4 text-left">
      <blockquote class="text-sm italic text-slate-300">
        "Quote from coordinator here."
      </blockquote>
      <figcaption class="mt-3 text-xs text-slate-500">
        — Name, Role, University
      </figcaption>
    </figure>
    -->

    <!-- Compact feature strip -->
    <div class="mt-16 border-t border-slate-800 pt-12 grid grid-cols-2 gap-4 sm:grid-cols-4 text-left">
      {points.map((p) => (
        <div class="rounded-lg border border-slate-700/60 bg-slate-800/30 px-4 py-4">
          <h3 class="text-xs font-semibold text-white">{p.title}</h3>
          <p class="mt-1.5 text-xs text-slate-400 leading-relaxed">{p.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
