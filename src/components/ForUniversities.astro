---
const DEMO_MAILTO = "mailto:alessandromiccolo2003@gmail.com?subject=MSC%20Study%20Planner%20Demo%20Request&body=University%20name%3A%0AProgramme%3A%0AYour%20role%3A";
const points = [
  { title: "Branded for your institution", body: "Each university gets its own catalogue, rules, branding, and subdomain. Ready to deploy for your programme." },
  { title: "Zero onboarding cost for students", body: "No account required to plan. Students land, build, validate, share — all without IT involvement on your side." },
  { title: "Programme analytics for coordinators", body: "See aggregate elective demand, common invalid configurations, and where students get stuck — anonymised, opt-in." },
  { title: "We handle the rules", body: "Send us your programme guide; we encode the validation logic and keep it up to date each academic year." },
];

const demoSteps = [
  "We walk through the live planner and show real validation in action.",
  "You describe your programme structure and rules.",
  "We give you a setup estimate and a price on the spot — no strings.",
];
---

<section id="universities" class="border-b border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <div class="grid gap-12 lg:grid-cols-[1fr_2fr] lg:gap-16">

      <!-- Left column -->
      <div>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Bring it to your campus</h2>

        <!-- Opening pain line -->
        <p class="mt-4 text-base font-medium text-blue-400">
          Hundreds of plan validation emails pile up in your inbox every term. They should not be part of your job description.
        </p>
        <p class="mt-4 text-slate-300">
          MSC Study Planner is built to deploy across programmes and institutions. If you coordinate an MSc and want fewer plan emails next term, the 20-minute call below is all it takes to find out if it fits.
        </p>

        <!-- CTA -->
        <a
          href={DEMO_MAILTO}
          class="mt-8 inline-flex items-center justify-center rounded-md bg-blue-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-blue-900/50 transition hover:bg-blue-500"
        >
          Book a 20-min demo
        </a>

        <!-- What happens in the call -->
        <div class="mt-6 rounded-lg border border-slate-700 bg-slate-800/40 px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">What happens in the 20 minutes</p>
          <ul class="mt-3 space-y-2">
            {demoSteps.map((step) => (
              <li class="flex items-start gap-2 text-sm text-slate-300">
                <span class="mt-0.5 flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white">✓</span>
                {step}
              </li>
            ))}
          </ul>
        </div>

        <!-- GDPR block -->
        <div class="mt-4 rounded-lg border border-slate-700 bg-slate-800/40 px-5 py-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-blue-400">Data &amp; Privacy</p>
          <p class="mt-1 text-sm text-slate-300">
            Student plans are stored locally in the browser by default. No data leaves the student's machine unless they choose to share. All shared data is stored on EU infrastructure and never used for training or shared with third parties.
            <span class="font-medium text-white">GDPR-compliant by design.</span>
          </p>
        </div>

        <!-- Testimonial placeholder — uncomment and fill in when first coordinator quote is received
        <figure class="mt-6 rounded-lg border border-slate-700 bg-slate-800/40 px-5 py-4">
          <blockquote class="text-sm italic text-slate-300">
            "Quote from coordinator here."
          </blockquote>
          <figcaption class="mt-3 text-xs text-slate-500">
            — Name, Role, University
          </figcaption>
        </figure>
        -->
      </div>

      <!-- Right column: feature cards -->
      <div class="grid gap-5 sm:grid-cols-2">
        {points.map((p) => (
          <div class="rounded-xl border border-slate-700 bg-slate-800/60 p-6 backdrop-blur">
            <h3 class="font-semibold text-white">{p.title}</h3>
            <p class="mt-2 text-sm text-slate-300">{p.body}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
