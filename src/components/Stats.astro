---
const stats = [
  { value: "~2 hrs", label: "saved per student per year", sub: "coordinator time on plan validation" },
  { value: "< 2 weeks", label: "to go live", sub: "typical programme onboarding time" },
  { value: "0", label: "invalid plans", sub: "target state after deployment" },
];
---

<section class="border-b border-slate-200 bg-white">
  <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
    <div class="grid gap-8 sm:grid-cols-3">
      {stats.map((s) => (
        <div class="text-center">
          <p class="text-5xl font-bold tracking-tight text-blue-600">{s.value}</p>
          <p class="mt-2 text-base font-semibold text-slate-900">{s.label}</p>
          <p class="mt-1 text-sm text-slate-500">{s.sub}</p>
        </div>
      ))}
    </div>
    <p class="mt-8 text-center text-xs text-slate-400">
      Based on TU Delft Aerospace Engineering pilot · estimates subject to programme complexity
    </p>
  </div>
</section>
