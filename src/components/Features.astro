---
const features = [
  { title: "Guided setup", body: "Programme, track, and sub-track selection pre-loads the right mandatory courses automatically." },
  { title: "AI course recommendations", body: "Personalised elective suggestions based on the student's profile and the full course catalogue." },
  { title: "Real-time ECTS validation", body: "Live credit totals with instant flags for shortfalls, overloads, and prerequisite violations." },
  { title: "A/B plan comparison", body: "Students can build and compare two plan variants side-by-side before committing." },
  { title: "Advisor share links", body: "One shareable URL per plan — no account needed for the advisor to view or comment." },
  { title: "Multi-university ready", body: "Each institution gets its own branded subdomain, catalogue, and rules. Completely separate from other institutions." },
];
---

<section class="border-b border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
    <h2 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">What's included</h2>
    <p class="mt-4 max-w-xl text-slate-600">Everything a student needs to build a valid plan. Everything a coordinator needs to stop reviewing them manually.</p>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="group rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-md">
          <div class="mb-3 h-1 w-8 rounded-full bg-blue-600 transition-all group-hover:w-12"></div>
          <h3 class="font-semibold text-slate-900">{f.title}</h3>
          <p class="mt-2 text-sm text-slate-500">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
