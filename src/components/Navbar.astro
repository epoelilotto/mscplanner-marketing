---
const PLANNER_URL = "https://ae-planner-proxy.vercel.app";
const DEMO_MAILTO = "mailto:alessandromiccolo2003@gmail.com?subject=MSC%20Study%20Planner%20Demo%20Request&body=University%20name%3A%0AProgramme%3A%0AYour%20role%3A";
const navLinks = [
  { href: "/#how-it-works", label: "How it works" },
  { href: "/#universities", label: "Bring it to your campus" },
  { href: "/#faq", label: "FAQ" },
  { href: PLANNER_URL, label: "Demo", external: true },
  { href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/95 backdrop-blur">
  <input type="checkbox" id="nav-toggle" class="peer sr-only" />

  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 h-16">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 text-white font-semibold text-base tracking-tight shrink-0">
      <!-- SVG logo mark: blue rounded square with white checkmark -->
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="28" height="28" rx="7" fill="#2563EB"/>
        <path d="M8 14.5l4 4 8-9" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      MSC Study Planner
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((l) => (
        <a
          href={l.href}
          target={l.external ? "_blank" : undefined}
          rel={l.external ? "noreferrer" : undefined}
          class="rounded-md px-3 py-2 text-sm font-medium text-slate-300 transition hover:bg-slate-800 hover:text-white"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA: white background, black bold text -->
    <a
      href={DEMO_MAILTO}
      class="hidden md:inline-flex items-center justify-center rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow shadow-blue-900/50 transition hover:bg-blue-500"
    >
      Book a demo
    </a>

    <!-- Mobile hamburger -->
    <label
      for="nav-toggle"
      class="md:hidden flex cursor-pointer items-center rounded-md p-2 text-slate-300 hover:bg-slate-800 hover:text-white"
      aria-label="Toggle navigation menu"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
  </div>

  <!-- Mobile menu -->
  <div class="hidden peer-checked:block md:hidden border-t border-slate-800 bg-slate-950 px-4 pb-4 pt-2">
    {navLinks.map((l) => (
      <a
        href={l.href}
        target={l.external ? "_blank" : undefined}
        rel={l.external ? "noreferrer" : undefined}
        class="block rounded-md px-4 py-3 text-sm font-medium text-slate-300 hover:bg-slate-800 hover:text-white"
      >
        {l.label}
      </a>
    ))}
    <a
      href={DEMO_MAILTO}
      class="mt-3 block rounded-md bg-blue-600 px-4 py-3 text-center text-sm font-semibold text-white hover:bg-blue-500"
    >
      Book a demo
    </a>
  </div>
</header>
