---
const PLANNER_URL = "https://ae-planner-proxy.vercel.app";
const DEMO_MAILTO = "mailto:alessandromiccolo2003@gmail.com?subject=MSC%20Study%20Planner%20Demo%20Request&body=University%20name%3A%0AProgramme%3A%0AYour%20role%3A";
const navLinks = [
  { href: "/#how-it-works", label: "How it works", external: false },
  { href: "/#universities", label: "For universities", external: false },
  { href: PLANNER_URL, label: "Demo", external: true },
  { href: "/contact", label: "Contact", external: false },
];
---

<header class="sticky top-0 z-50 border-b border-slate-800 bg-slate-950/95 backdrop-blur">
  <input type="checkbox" id="nav-toggle" class="peer sr-only" />

  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 h-16">
    <a href="/" class="flex items-center gap-2 text-white font-semibold text-lg tracking-tight shrink-0">
      <span class="flex h-7 w-7 items-center justify-center rounded-md bg-blue-600 text-xs font-bold text-white">M</span>
      MSC Study Planner
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {navLinks.map((l) => (
        <a
          href={l.href}
          target={l.external ? "_blank" : undefined}
          rel={l.external ? "noreferrer" : undefined}
          class="rounded-md px-4 py-2 text-sm font-medium text-slate-300 transition hover:bg-slate-800 hover:text-white"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <a
      href={DEMO_MAILTO}
      class="hidden md:inline-flex items-center justify-center rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow shadow-blue-900/50 transition hover:bg-blue-500"
    >
      Book a demo
    </a>

    <label
      for="nav-toggle"
      class="md:hidden flex cursor-pointer items-center rounded-md p-2 text-slate-300 hover:bg-slate-800 hover:text-white"
      aria-label="Toggle navigation menu"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>
  </div>

  <div class="hidden peer-checked:block md:hidden border-t border-slate-800 bg-slate-950 px-4 pb-4 pt-2">
    {navLinks.map((l) => (
      <a
        href={l.href}
        target={l.external ? "_blank" : undefined}
        rel={l.external ? "noreferrer" : undefined}
        class="block rounded-md px-4 py-3 text-sm font-medium text-slate-300 hover:bg-slate-800 hover:text-white"
      >
        {l.label}
      </a>
    ))}
    <a
      href={DEMO_MAILTO}
      class="mt-3 block rounded-md bg-blue-600 px-4 py-3 text-center text-sm font-semibold text-white hover:bg-blue-500"
    >
      Book a demo
    </a>
    <a
      href={PLANNER_URL}
      target="_blank"
      rel="noreferrer"
      class="mt-2 block rounded-md border border-slate-700 px-4 py-3 text-center text-sm font-medium text-slate-300 hover:text-white"
    >
      Open MSC Study Planner →
    </a>
  </div>
</header>
