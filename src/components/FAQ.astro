---
const faqs = [
  {
    q: "What is MSc Study Planner?",
    a: "MSc Study Planner is an AI-powered study planning tool built for MSc programmes at technical universities. It lets students build and validate their course selections against official programme rules in real time — so coordinators receive fewer invalid plans and spend less time on email back-and-forth.",
  },
  {
    q: "Which MSc programmes and universities can use it?",
    a: "MSc Study Planner is designed for any university running elective-heavy MSc programmes — especially technical universities with track- or profile-based degree structures. It is currently live for MSc Aerospace Engineering students and is being onboarded at other European universities across CS, Data Science, and Engineering programmes.",
  },
  {
    q: "How long does it take to set up the study planner for my MSc programme?",
    a: "About two weeks. You send us your programme guide; we encode the validation rules and you review them before the planner goes live for your students. No IT involvement needed on your side.",
  },
  {
    q: "What does it cost for a university?",
    a: "Pricing is per-institution and depends on programme size. We'll give you a number in the first call — no commitment needed to hear it.",
  },
  {
    q: "Is student data safe and GDPR-compliant?",
    a: "Yes. Plans are stored locally in the student's browser by default — no data reaches our servers unless the student explicitly shares their plan. All shared data is stored on EU infrastructure and never used for training or sold to third parties. MSc Study Planner is GDPR-compliant by design.",
  },
  {
    q: "Does the MSc planner connect to our student information system?",
    a: "Not yet. MSc Study Planner works standalone today — students use it alongside whatever SIS your university already has. Integration with SIS and course catalogues is on the roadmap.",
  },
  {
    q: "What if our MSc programme rules change each academic year?",
    a: "We update the validation logic each academic year as part of the subscription. Send us the new programme guide and we'll handle the rest — no work on your side.",
  },
  {
    q: "Can students use the MSc study planner without creating an account?",
    a: "Yes. Plans are saved in the browser by default — no sign-up required. Students can optionally create an account to sync their study plan across devices and share it directly with their university advisor.",
  },
];

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
});
---

<script type="application/ld+json" set:html={faqJsonLd} />

<section id="faq-section" class="border-b border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-3xl px-6 py-20 sm:py-24">
    <h2 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
      Common questions
    </h2>
    <dl class="mt-10 space-y-4">
      {faqs.map((item) => (
        <details class="group rounded-xl border border-slate-200 bg-white shadow-sm">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5 text-base font-semibold text-slate-900 marker:hidden [&::-webkit-details-marker]:hidden">
            {item.q}
            <span class="shrink-0 text-slate-400 transition group-open:rotate-180">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6" />
              </svg>
            </span>
          </summary>
          <div class="border-t border-slate-100 px-6 pb-5 pt-4 text-slate-600">
            {item.a}
          </div>
        </details>
      ))}
    </dl>
  </div>
</section>
